          <argument>
            <kind>1</kind>
            <string>scr_joy();
scr_input();

if ((pressescape &amp;&amp; !pressescapeprev) || (pressinteract &amp;&amp; !pressinteractprev)){
    global.destination=2;
    global.overridedir=1;
    global.overridedirout=3;
    room_goto(rom_nowhere);
    }</string>
          </argument>
